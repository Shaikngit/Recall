using './main.bicep'

param environmentName = readEnvironmentVariable('AZURE_ENV_NAME', 'recall')
param location = readEnvironmentVariable('AZURE_LOCATION', 'westus2')
param existingAppServicePlanName = readEnvironmentVariable('AZURE_RECALL_EXISTING_APP_SERVICE_PLAN_NAME', '')
param existingWebAppName = readEnvironmentVariable('AZURE_RECALL_EXISTING_WEB_APP_NAME', '')
param appServiceDelegationName = readEnvironmentVariable('AZURE_RECALL_APPSVC_DELEGATION_NAME', 'appServiceDelegation')
param appServiceIntegrationPrivateEndpointNetworkPolicies = readEnvironmentVariable('AZURE_RECALL_APPSVC_INTEGRATION_PRIVATE_ENDPOINT_POLICIES', 'Enabled')
param openAIMode = readEnvironmentVariable('AZURE_OPENAI_MODE', 'existing')
param openAIResourceId = readEnvironmentVariable('AZURE_OPENAI_RESOURCE_ID', '')
param openAIDeploymentName = readEnvironmentVariable('AZURE_OPENAI_DEPLOYMENT', '')
param openAIModelName = readEnvironmentVariable('AZURE_OPENAI_MODEL_NAME', 'gpt-4.1-mini')
param openAIDeploymentCapacity = int(readEnvironmentVariable('AZURE_OPENAI_DEPLOYMENT_CAPACITY', '1'))
param openAINewAccountName = readEnvironmentVariable('AZURE_OPENAI_ACCOUNT_NAME', '')
param assignOpenAIRole = bool(readEnvironmentVariable('AZURE_OPENAI_ASSIGN_ROLE', 'true'))
param enableBlobContent = bool(readEnvironmentVariable('AZURE_RECALL_ENABLE_BLOB_CONTENT', 'false'))
param blobStorageAccountName = readEnvironmentVariable('AZURE_RECALL_BLOB_STORAGE_ACCOUNT_NAME', '')
param blobStorageResourceGroupName = readEnvironmentVariable('AZURE_RECALL_BLOB_STORAGE_RESOURCE_GROUP', '')
param blobContainerName = readEnvironmentVariable('AZURE_RECALL_BLOB_CONTAINER', 'mykb-content')
param blobCacheRoot = readEnvironmentVariable('AZURE_RECALL_BLOB_CACHE_ROOT', '/tmp/mykb-content-cache')
param blobRefreshSeconds = int(readEnvironmentVariable('AZURE_RECALL_BLOB_REFRESH_SECONDS', '30'))
param blobBootstrapRoot = readEnvironmentVariable('AZURE_RECALL_BLOB_BOOTSTRAP_ROOT', '')
param enableBlobPrivateNetworking = bool(readEnvironmentVariable('AZURE_RECALL_ENABLE_BLOB_PRIVATE_NETWORKING', 'false'))
param existingVirtualNetworkName = readEnvironmentVariable('AZURE_RECALL_VNET_NAME', '')
param existingVirtualNetworkResourceGroupName = readEnvironmentVariable('AZURE_RECALL_VNET_RESOURCE_GROUP', '')
param appServiceIntegrationSubnetName = readEnvironmentVariable('AZURE_RECALL_APPSVC_INTEGRATION_SUBNET_NAME', 'appsvc-integration-subnet')
param appServiceIntegrationSubnetPrefix = readEnvironmentVariable('AZURE_RECALL_APPSVC_INTEGRATION_SUBNET_PREFIX', '10.0.1.0/24')
param storagePrivateEndpointSubnetName = readEnvironmentVariable('AZURE_RECALL_STORAGE_PE_SUBNET_NAME', 'storage-private-endpoint-subnet')
param storagePrivateEndpointSubnetPrefix = readEnvironmentVariable('AZURE_RECALL_STORAGE_PE_SUBNET_PREFIX', '10.0.2.0/24')
param storagePrivateEndpointSubnetNetworkSecurityGroupResourceId = readEnvironmentVariable('AZURE_RECALL_STORAGE_PE_SUBNET_NSG_ID', '')
param blobPrivateEndpointName = readEnvironmentVariable('AZURE_RECALL_STORAGE_PRIVATE_ENDPOINT_NAME', '')
param blobPrivateEndpointConnectionName = readEnvironmentVariable('AZURE_RECALL_STORAGE_PRIVATE_ENDPOINT_CONNECTION_NAME', '')
param blobPrivateDnsZoneName = readEnvironmentVariable('AZURE_RECALL_BLOB_PRIVATE_DNS_ZONE_NAME', 'privatelink.blob.core.windows.net')
param blobPrivateDnsZoneConfigName = readEnvironmentVariable('AZURE_RECALL_BLOB_PRIVATE_DNS_ZONE_CONFIG_NAME', 'blob')
param blobPrivateDnsZoneVnetLinkName = readEnvironmentVariable('AZURE_RECALL_BLOB_PRIVATE_DNS_LINK_NAME', 'mykb-blob-dns-link')
param blobPrivateDnsZoneResolutionPolicy = readEnvironmentVariable('AZURE_RECALL_BLOB_PRIVATE_DNS_RESOLUTION_POLICY', 'Default')
param blobPrivateDnsZoneGroupName = readEnvironmentVariable('AZURE_RECALL_BLOB_PRIVATE_DNS_ZONE_GROUP_NAME', 'default')
